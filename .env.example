# Vibe Trading Configuration Template

# Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ANALYST_MODEL=gemini-3.5-flash
GEMINI_TRADER_MODEL=gemini-2.5-flash

# Langfuse Observability Configuration (optional, obtain from Langfuse Cloud)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Discord Alert Configuration (optional webhook URL)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Trading execution configuration
# Options: BACKTEST, PAPER, LIVE_SANDBOX
TRADING_MODE=PAPER

# Coinbase Advanced API Credentials (sandbox/test credentials)
COINBASE_API_KEY_NAME=your_coinbase_api_key_name_here
COINBASE_API_KEY_SECRET=your_coinbase_api_key_secret_here

# Database path (DuckDB single-file database)
DATABASE_PATH=data/vibe_trading.db

# Provider-Agnostic LLM Configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

