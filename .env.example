# Vibe Trading Configuration Template

# Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ANALYST_MODEL=gemini-3.5-flash
GEMINI_TRADER_MODEL=gemini-2.5-flash

# Langfuse Observability Configuration (optional, obtain from Langfuse Cloud)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Discord Alert Configuration (optional webhook URL)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Trading execution configuration
# Options: BACKTEST, PAPER, LIVE_SANDBOX
TRADING_MODE=PAPER

# Coinbase Advanced API Credentials (sandbox/test credentials)
COINBASE_API_KEY_NAME=your_coinbase_api_key_name_here
COINBASE_API_KEY_SECRET=your_coinbase_api_key_secret_here

# Database path (DuckDB single-file database)
DATABASE_PATH=data/vibe_trading.db

# Provider-Agnostic LLM Configuration
# Supported providers: gemini | openai | anthropic | groq | ollama
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GROQ_API_KEY=your_groq_key_here

# Recommended Groq config (faster, far higher rate limits, open-weights):
#   LLM_PROVIDER=groq
#   LLM_MODEL=llama-3.3-70b-versatile

# Eval-harness judge model (overrides LLM_MODEL for rubric scoring only)
# EVAL_JUDGE_MODEL=mistral-small-latest

# Daily LLM spend (USD) above which the scheduler sends a Discord cost alarm (warn)
LLM_DAILY_COST_ALARM_USD=5.0
# Hard daily LLM spend (USD) cap: once reached, NEW-entry evaluation is blocked for
# the rest of the UTC day (open positions still managed). Set <= 0 to disable.
LLM_DAILY_COST_CAP_USD=10.0


# --- Binance USDⓂ Futures DEMO TRADING execution (TRADING_MODE=LIVE_TESTNET) ---
# Create demo-trading API keys at https://demo.binance.com (Account → API Management),
# with Reading + Futures enabled. They route to the demo endpoint (demo-fapi.binance.com)
# — never real funds. (Var names keep the *_TESTNET_* prefix for back-compat; demo keys.)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_DRY_RUN=false      # true = log intended orders, place none (safe wiring check)
BINANCE_TESTNET_LEVERAGE=1
# BINANCE_DEMO_FAPI_URL=https://demo-fapi.binance.com  # override the demo REST base if needed
# TRADING_MODE=LIVE_TESTNET         # uncomment to activate the futures broker
